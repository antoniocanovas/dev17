<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    # BASE AUTOMATION:
    <record id="auto_update_check_out" model="base.automation">
        <field name="name">=> Auto update checkout</field>
        <field name="model_id" ref="hr_attendance_gantt.model_hr_attendance"/>
        <field name="trigger">on_create</field>
        <field name="filter_pre_domain"></field>
        <field name="filter_domain"></field>
        <field name="active" eval="True"/>
    </record>

    # SERVER ACTION:
    <record id="as_auto_update_check_out" model="ir.actions.server">
        <field name="name">=> AS Auto update checkout</field>
        <field name="model_id" ref="hr_attendance_gantt.model_hr_attendance"/>
        <field name="evaluation_type">value</field>
        <field name="code">
            record.auto_update_checkout()
        </field>
        <field name="base_automation_id" ref="custom_demesol_pnt.auto_update_check_out"/>
    </record>

</odoo>
