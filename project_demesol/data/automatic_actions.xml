<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    # BASE AUTOMATION:
    <record id="create_project_document_folders_aa" model="base.automation">
        <field name="name">=> Create initial project document folders</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="trigger">on_create</field>
        <field name="filter_pre_domain"></field>
        <field name="filter_domain"></field>
        <field name="active" eval="True"/>
    </record>

    # SERVER ACTION:
    <record id="create_project_document_folders_as" model="ir.actions.server">
        <field name="name">=> Create project document folders</field>
        <field name="model_id" ref="project.model_project_project"/>
        <field name="evaluation_type">value</field>
        <field name="state">code</field>
        <field name="code">
            record.create_new_documents_folders()
        </field>
        <field name="base_automation_id" ref="project_demesol.create_project_document_folders_aa"/>
    </record>

</odoo>
